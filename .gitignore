# pg_dump snapshots (CC8.1 compensating control, HUMAN-ACTIONS #13).
# Contienen PHI de las 12 firmas — NUNCA commitear.
# Generados por scripts/pre-migration-backup.sh.
backups/
*.sql.gz

# Reportes del orquestador — generados por scripts/orchestrator.ts
# Quedan locales por default (pueden tener decisiones sensibles).
# Si querés commitear uno específico: git add -f .ai/reportes/<archivo>.md
.ai/reportes/*.md

# Security audit dossiers — contienen repros de vulnerabilidades.
# Política: estos dossiers viven en almacén privado (Drive/Notion con
# audit trail de acceso), NO en git. Si necesitás referenciar uno desde
# un ticket, linkeá al storage privado.
.ai/master/security-audit-*.md

# Raw responses de agentes (debug del orquestador, no van a prod)
.ai/debug-raw/

# Mockups generados automáticamente por Valerie vía orquestador
mockups/auto-*.html

# Mockups manuales de referencia visual (no son código de producción)
mockups/2026-*.html

# Logos test de firmas piloto (en prod salen de office_config.logo_url)
public/brand/firms/

# Playwright artifacts (Sprint A). Baselines en tests/screenshots SÍ se commitean.
playwright-report/
test-results/
/tests/screenshots/**/*-actual.png
/tests/screenshots/**/*-diff.png
