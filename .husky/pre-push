#!/usr/bin/env bash
# .husky/pre-push — NER pre-push gate (Sprint A, locked 2026-06-06).
#
# Corre 3 checks fast (<30s) ANTES de cualquier git push:
#   1. TypeScript noEmit
#   2. Build Vite production (cazas Tailwind JIT issues + imports rotos)
#   3. Grep anti-patterns conocidos (className dinámico, etc)
#
# Si CUALQUIERA falla → push abortado. Mr. Lorenzo NO ve el bug.
#
# Por qué NO corre Playwright acá:
#   - Playwright + Chromium = lento (3-5 min)
#   - Pre-push hook debe ser <30s sino developers lo deshabilitan
#   - Playwright vive en CI (.github/workflows/e2e.yml)
#
# Para BYPASS temporal (URGENT only):
#   git push --no-verify
#   Pero después abrir PR con explicación + fix.

set -e

CYAN='\033[0;36m'
RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'

echo -e "${CYAN}╭─────────────────────────────────────────────╮${NC}"
echo -e "${CYAN}│   NER pre-push gate · Sprint A protections   │${NC}"
echo -e "${CYAN}╰─────────────────────────────────────────────╯${NC}"

# ─── Check 1: TypeScript ───────────────────────────────────
echo -e "\n${CYAN}[1/3]${NC} TypeScript noEmit…"
if ! bunx tsc --noEmit 2>&1 | tail -20; then
  echo -e "${RED}✘ TypeScript errors. Push abortado.${NC}"
  exit 1
fi
echo -e "${GREEN}✓ TypeScript clean${NC}"

# ─── Check 2: Build production ─────────────────────────────
echo -e "\n${CYAN}[2/3]${NC} Vite production build…"
if ! bun run build > /tmp/ner-prepush-build.log 2>&1; then
  echo -e "${RED}✘ Build falló. Última 30 líneas:${NC}"
  tail -30 /tmp/ner-prepush-build.log
  echo -e "${RED}Push abortado. Fix el build primero.${NC}"
  exit 1
fi
echo -e "${GREEN}✓ Build OK${NC}"

# ─── Check 3: Anti-pattern grep ────────────────────────────
echo -e "\n${CYAN}[3/3]${NC} Anti-pattern grep (Tailwind JIT, etc)…"

FAIL=0

# Pattern A: dynamic Tailwind class interpolation INSIDE arbitrary brackets.
# El bug real: `grid-cols-[repeat(${N},1fr)_auto]` — Tailwind JIT no compila
# valores arbitrarios con ${} dentro de [], cae a default y colapsa el layout.
#
# False-positive fix R9.13: el regex anterior matcheaba CUALQUIER className con
# ${} + [] en cualquier orden — flagged 15 archivos OK (ej. `${grad}` + `[10px]`
# en la misma línea son ambos seguros porque ${grad} es un string completo y
# [10px] es bracket sin interpolación). El nuevo regex EXIGE que el ${ aparezca
# DENTRO de un [...] sin ] intermedio — solo cazado el patrón peligroso real.
if matches=$(grep -REn 'className=\{`[^`]*\[[^]]*\$\{' src/ 2>/dev/null); then
  if [ -n "$matches" ]; then
    echo -e "${RED}✘ Pattern A — Tailwind JIT dynamic class:${NC}"
    echo "$matches"
    echo -e "${RED}  Fix: usar inline style={{}} o safelist map literal${NC}"
    FAIL=1
  fi
fi

# Pattern B: console.log left in non-test code (no debe llegar a prod)
if matches=$(grep -REn 'console\.log\(' src/ --exclude-dir=__tests__ --exclude='*.test.*' 2>/dev/null | grep -v '// debug-OK' | head -5); then
  if [ -n "$matches" ]; then
    echo -e "${RED}⚠ Pattern B — console.log en src/ (top 5):${NC}"
    echo "$matches"
    echo -e "${RED}  Si es intencional, agregá comentario '// debug-OK' al lado${NC}"
    # Warning solamente, no abort
  fi
fi

# Pattern D: SWC ternary-JSX-comment bug (Round 9.27 lección).
# Caso peligroso: `) : (` seguido en línea siguiente por `{/* ... */}`.
# tsc lo acepta, SWC lo rechaza con "expected ')' but found '...'".
# Bug Mr. Lorenzo 2026-06-06: build de Lovable falló por esto.
#
# Detección con awk porque necesita mirar línea N + N+1.
matches=$(find src -type f \( -name '*.tsx' -o -name '*.jsx' \) -exec awk '
  /\) : \([[:space:]]*$/ {
    line = NR
    next_check = 1
    next
  }
  next_check == 1 {
    if ($0 ~ /^[[:space:]]*\{\/\*/) {
      print FILENAME ":" line ": ternary `) : (` seguido por comentario JSX `{/* */}` — SWC build fail"
      found = 1
    }
    next_check = 0
  }
  END { if (found) exit 1 }
' {} \; 2>/dev/null)
if [ -n "$matches" ]; then
  echo -e "${RED}✘ Pattern D — SWC ternary-JSX-comment bug:${NC}"
  echo "$matches"
  echo -e "${RED}  Fix: cambiar {/* ... */} a // comentario JS, o wrappear con <>...</>${NC}"
  FAIL=1
fi

# Pattern C: TODO/FIXME en código nuevo (warning only)
if matches=$(git diff --cached -U0 2>/dev/null | grep -E '^\+.*(TODO|FIXME):' | head -3); then
  if [ -n "$matches" ]; then
    echo -e "${CYAN}ℹ TODOs/FIXMEs nuevos detectados:${NC}"
    echo "$matches"
  fi
fi

if [ $FAIL -eq 1 ]; then
  echo -e "\n${RED}Push abortado por anti-patterns. Fix arriba.${NC}"
  exit 1
fi
echo -e "${GREEN}✓ Anti-patterns clean${NC}"

# ─── Done ───────────────────────────────────────────────────
echo -e "\n${GREEN}╭─────────────────────────────────────────────╮${NC}"
echo -e "${GREEN}│   All checks passed. Pushing…              │${NC}"
echo -e "${GREEN}╰─────────────────────────────────────────────╯${NC}"
