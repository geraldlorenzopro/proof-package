#!/usr/bin/env bash
# .husky/pre-push вҖ” NER pre-push gate (Sprint A, locked 2026-06-06).
#
# Corre 3 checks fast (<30s) ANTES de cualquier git push:
#   1. TypeScript noEmit
#   2. Build Vite production (cazas Tailwind JIT issues + imports rotos)
#   3. Grep anti-patterns conocidos (className dinГЎmico, etc)
#
# Si CUALQUIERA falla вҶ’ push abortado. Mr. Lorenzo NO ve el bug.
#
# Por quГ© NO corre Playwright acГЎ:
#   - Playwright + Chromium = lento (3-5 min)
#   - Pre-push hook debe ser <30s sino developers lo deshabilitan
#   - Playwright vive en CI (.github/workflows/e2e.yml)
#
# Para BYPASS temporal (URGENT only):
#   git push --no-verify
#   Pero despuГ©s abrir PR con explicaciГіn + fix.

set -e

CYAN='\033[0;36m'
RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'

echo -e "${CYAN}в•ӯв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•®${NC}"
echo -e "${CYAN}в”Ӯ   NER pre-push gate В· Sprint A protections   в”Ӯ${NC}"
echo -e "${CYAN}в•°в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•Ҝ${NC}"

# в”Җв”Җв”Җ Check 1: TypeScript в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
echo -e "\n${CYAN}[1/3]${NC} TypeScript noEmitвҖҰ"
if ! bunx tsc --noEmit 2>&1 | tail -20; then
  echo -e "${RED}вңҳ TypeScript errors. Push abortado.${NC}"
  exit 1
fi
echo -e "${GREEN}вң“ TypeScript clean${NC}"

# в”Җв”Җв”Җ Check 2: Build production в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
echo -e "\n${CYAN}[2/3]${NC} Vite production buildвҖҰ"
if ! bun run build > /tmp/ner-prepush-build.log 2>&1; then
  echo -e "${RED}вңҳ Build fallГі. Гҡltima 30 lГӯneas:${NC}"
  tail -30 /tmp/ner-prepush-build.log
  echo -e "${RED}Push abortado. Fix el build primero.${NC}"
  exit 1
fi
echo -e "${GREEN}вң“ Build OK${NC}"

# в”Җв”Җв”Җ Check 3: Anti-pattern grep в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
echo -e "\n${CYAN}[3/3]${NC} Anti-pattern grep (Tailwind JIT, etc)вҖҰ"

FAIL=0

# Pattern A: dynamic Tailwind class interpolation INSIDE arbitrary brackets.
# El bug real: `grid-cols-[repeat(${N},1fr)_auto]` вҖ” Tailwind JIT no compila
# valores arbitrarios con ${} dentro de [], cae a default y colapsa el layout.
#
# False-positive fix R9.13: el regex anterior matcheaba CUALQUIER className con
# ${} + [] en cualquier orden вҖ” flagged 15 archivos OK (ej. `${grad}` + `[10px]`
# en la misma lГӯnea son ambos seguros porque ${grad} es un string completo y
# [10px] es bracket sin interpolaciГіn). El nuevo regex EXIGE que el ${ aparezca
# DENTRO de un [...] sin ] intermedio вҖ” solo cazado el patrГіn peligroso real.
if matches=$(grep -REn 'className=\{`[^`]*\[[^]]*\$\{' src/ 2>/dev/null); then
  if [ -n "$matches" ]; then
    echo -e "${RED}вңҳ Pattern A вҖ” Tailwind JIT dynamic class:${NC}"
    echo "$matches"
    echo -e "${RED}  Fix: usar inline style={{}} o safelist map literal${NC}"
    FAIL=1
  fi
fi

# Pattern B: console.log left in non-test code (no debe llegar a prod)
if matches=$(grep -REn 'console\.log\(' src/ --exclude-dir=__tests__ --exclude='*.test.*' 2>/dev/null | grep -v '// debug-OK' | head -5); then
  if [ -n "$matches" ]; then
    echo -e "${RED}вҡ  Pattern B вҖ” console.log en src/ (top 5):${NC}"
    echo "$matches"
    echo -e "${RED}  Si es intencional, agregГЎ comentario '// debug-OK' al lado${NC}"
    # Warning solamente, no abort
  fi
fi

# Pattern C: TODO/FIXME en cГіdigo nuevo (warning only)
if matches=$(git diff --cached -U0 2>/dev/null | grep -E '^\+.*(TODO|FIXME):' | head -3); then
  if [ -n "$matches" ]; then
    echo -e "${CYAN}в„№ TODOs/FIXMEs nuevos detectados:${NC}"
    echo "$matches"
  fi
fi

if [ $FAIL -eq 1 ]; then
  echo -e "\n${RED}Push abortado por anti-patterns. Fix arriba.${NC}"
  exit 1
fi
echo -e "${GREEN}вң“ Anti-patterns clean${NC}"

# в”Җв”Җв”Җ Done в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
echo -e "\n${GREEN}в•ӯв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•®${NC}"
echo -e "${GREEN}в”Ӯ   All checks passed. PushingвҖҰ              в”Ӯ${NC}"
echo -e "${GREEN}в•°в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•Ҝ${NC}"
